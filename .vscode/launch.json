{
    "configurations": [
        {
            "name": "(gdb) Launch - mid2agb",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/X-CppReferences/mid2agb/mid2agb",
            "args": ["mus_route104.mid", "-E", "-R50", "-G_route104", "-V097"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch - midi2agb",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/X-CppReferences/midi2agb/midi2agb",
            "args": ["-r", "50", "-g", "voicegroup_route104", "-m", "97", "mus_route104.mid"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ],
    "version": "2.0.0"
}